{
    "env": {
        "browser": true,
        "es2020": true
    },
    "extends": ["salt", "salt/react", "salt/react/hooks"],
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 11,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
      "react/jsx-closing-bracket-location": [
        "error",
        { "selfClosing": "after-props", "nonEmpty": "after-props" }
      ],
      "react/jsx-filename-extension": ["error", { "extensions": [".js"] }]
    }
}
